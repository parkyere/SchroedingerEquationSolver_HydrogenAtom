{
    "version": "0.2.0",
    "configurations": [
        {
            // F5 (VS Code on Linux): configure-if-needed + build via the
            // PINNED linux-clang22 preset (tasks.json), then debug under gdb.
            // No CMake Tools state is involved anywhere -- a fresh clone F5s
            // immediately (after the one-time vcpkg bootstrap). Note this is
            // the Release preset: optimized code under the debugger (the
            // Debug preset's 3D physics crawl).
            //
            // Windows uses Visual Studio directly (CMakePresets.json): set
            // the startup item to the sesolver_app.exe CMake target. If VS
            // surfaces THIS entry in its startup dropdown, ignore it (gdb
            // cannot debug MSVC binaries).
            "name": "sesolver_app (Linux/gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/build/linux-clang22/app/sesolver_app",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/out/build/linux-clang22/app",
            "environment": [],
            "MIMode": "gdb",
            "miDebuggerPath": "${workspaceFolder}/tools/gdb-vscode.sh",
            "preLaunchTask": "cmake-build-app",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            // DIAGNOSTIC variant: no preLaunchTask (isolates the debugger
            // from the build task) and full engine logging (the Debug
            // Console shows the complete adapter<->gdb MI transcript, so a
            // silent failure becomes readable). Binary must already be built.
            "name": "sesolver_app (diagnose)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/out/build/linux-clang22/app/sesolver_app",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/out/build/linux-clang22/app",
            "environment": [],
            "MIMode": "gdb",
            "miDebuggerPath": "${workspaceFolder}/tools/gdb-vscode.sh",
            "logging": {
                "engineLogging": true,
                "trace": true,
                "traceResponse": true
            },
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
